{
  "manifest_version": 3,
  "name": "TabVault",
  "version": "1.1.1",
  "description": "Backs up your tab groups locally and to your Google Drive, and restores them after a crash, reinstall, or on a new device.",
  "key": "",
  "minimum_chrome_version": "108",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "alarms",
    "identity",
    "offscreen"
  ],
  "host_permissions": [
    "https://www.googleapis.com/*",
    "https://oauth2.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "TabVault — back up and restore tab groups"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
